  <p style="margin-top: var(--space-4); max-width: 36rem;">
    Nothing lives at this address. Try the <a href="/posts/">posts</a>, the
    <a href="/apps/">apps</a>, or head <a href="/">home</a>.
  </p>
</BaseLayout>
